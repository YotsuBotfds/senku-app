<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_card_border" />
            <corners android:radius="18dp" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:centerColor="@color/senku_card"
                android:endColor="@color/senku_card_aged"
                android:startColor="@color/senku_card_warm_light" />
            <corners android:radius="17dp" />
            <stroke
                android:width="1dp"
                android:color="@color/senku_card_border" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#00000000"
                android:startColor="#14FFFFFF" />
            <corners android:radius="17dp" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:endColor="#0D6B7A4A"
                android:startColor="#00000000" />
            <corners android:radius="17dp" />
        </shape>
    </item>
</layer-list>
