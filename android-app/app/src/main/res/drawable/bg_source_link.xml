<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_bg_primary" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <item>
        <inset
            android:insetLeft="1dp"
            android:insetTop="1dp"
            android:insetRight="1dp"
            android:insetBottom="1dp">
            <shape android:shape="rectangle">
                <gradient
                    android:angle="0"
                    android:endColor="@color/senku_accent_olive_dark"
                    android:startColor="@color/senku_bg_olive" />
                <corners android:radius="15dp" />
                <stroke
                    android:width="1dp"
                    android:color="@color/senku_accent_olive" />
            </shape>
        </inset>
    </item>

    <item>
        <inset
            android:insetLeft="12dp"
            android:insetTop="10dp"
            android:insetRight="40dp"
            android:insetBottom="10dp">
            <shape android:shape="rectangle">
                <gradient
                    android:angle="0"
                    android:endColor="#00FFFFFF"
                    android:startColor="#14FFFFFF" />
                <corners android:radius="10dp" />
            </shape>
        </inset>
    </item>
</layer-list>
