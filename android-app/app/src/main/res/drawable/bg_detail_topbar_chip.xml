<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_bg_olive_deep" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="@color/senku_bg_olive"
                android:startColor="@color/senku_bg_surface" />
            <corners android:radius="11dp" />
            <stroke
                android:width="1dp"
                android:color="@color/senku_accent_olive_dark" />
        </shape>
    </item>

    <item
        android:left="8dp"
        android:top="6dp"
        android:right="8dp"
        android:bottom="10dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#00FFFFFF"
                android:startColor="#16FFFFFF" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</layer-list>
