<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_bg_primary" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:endColor="@color/senku_bg_olive_deep"
                android:startColor="@color/senku_bg_surface" />
            <corners android:radius="19dp" />
            <stroke
                android:width="1dp"
                android:color="@color/senku_accent_olive_dark" />
        </shape>
    </item>

    <item
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="12dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#00FFFFFF"
                android:startColor="#12FFFFFF" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</layer-list>
