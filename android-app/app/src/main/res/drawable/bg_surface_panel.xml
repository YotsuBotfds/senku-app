<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_bg_shadow_warm" />
            <corners android:radius="18dp" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:centerColor="@color/senku_bg_surface"
                android:endColor="@color/senku_bg_primary"
                android:startColor="@color/senku_bg_olive_deep" />
            <corners android:radius="17dp" />
            <stroke
                android:width="1dp"
                android:color="@color/senku_surface_stroke_soft" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#00000000"
                android:startColor="@color/senku_surface_glow_parchment" />
            <corners android:radius="17dp" />
        </shape>
    </item>
</layer-list>
