<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_bg_primary" />
            <corners android:radius="12dp" />
            <stroke
                android:width="1dp"
                android:color="@color/senku_surface_rule_warm" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="#08E8DCC8"
                android:startColor="#144A5238" />
            <corners android:radius="11dp" />
        </shape>
    </item>

    <item
        android:width="2dp"
        android:gravity="left"
        android:left="8dp"
        android:top="5dp"
        android:bottom="5dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_card_border" />
            <corners android:radius="1dp" />
        </shape>
    </item>

    <item
        android:width="8dp"
        android:height="2dp"
        android:gravity="left|top"
        android:left="8dp"
        android:top="5dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_card_border" />
            <corners android:radius="1dp" />
        </shape>
    </item>

    <item
        android:width="8dp"
        android:height="2dp"
        android:gravity="left|bottom"
        android:left="8dp"
        android:bottom="5dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_card_border" />
            <corners android:radius="1dp" />
        </shape>
    </item>

    <item
        android:width="2dp"
        android:gravity="right"
        android:right="8dp"
        android:top="5dp"
        android:bottom="5dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_card_border" />
            <corners android:radius="1dp" />
        </shape>
    </item>

    <item
        android:width="8dp"
        android:height="2dp"
        android:gravity="right|top"
        android:right="8dp"
        android:top="5dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_card_border" />
            <corners android:radius="1dp" />
        </shape>
    </item>

    <item
        android:width="8dp"
        android:height="2dp"
        android:gravity="right|bottom"
        android:right="8dp"
        android:bottom="5dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_card_border" />
            <corners android:radius="1dp" />
        </shape>
    </item>
</layer-list>
