<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_rev03_bg_2" />
            <corners android:radius="@dimen/senku_rev03_corner_medium" />
            <stroke
                android:width="1dp"
                android:color="@color/senku_rev03_hairline_strong" />
        </shape>
    </item>

    <item
        android:width="2dp"
        android:gravity="left"
        android:left="1dp"
        android:top="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_rev03_accent" />
            <corners
                android:topLeftRadius="2dp"
                android:bottomLeftRadius="2dp" />
        </shape>
    </item>
</layer-list>
