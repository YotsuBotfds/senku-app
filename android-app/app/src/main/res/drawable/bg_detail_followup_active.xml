<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:state_enabled="true"
        android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="0"
                        android:endColor="@color/senku_bg_olive"
                        android:startColor="@color/senku_bg_surface" />
                    <corners android:radius="16dp" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/senku_card_border" />
                </shape>
            </item>
            <item
                android:width="2dp"
                android:gravity="left"
                android:left="10dp"
                android:top="10dp"
                android:bottom="10dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/senku_surface_rule_warm" />
                    <corners android:radius="2dp" />
                </shape>
            </item>
            <item
                android:width="2dp"
                android:gravity="right"
                android:right="10dp"
                android:top="10dp"
                android:bottom="10dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/senku_surface_rule_warm" />
                    <corners android:radius="2dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item
        android:state_enabled="true"
        android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="0"
                        android:endColor="@color/senku_bg_olive"
                        android:startColor="@color/senku_bg_surface" />
                    <corners android:radius="16dp" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/senku_card_border" />
                </shape>
            </item>
            <item
                android:width="2dp"
                android:gravity="left"
                android:left="10dp"
                android:top="10dp"
                android:bottom="10dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/senku_surface_rule_warm" />
                    <corners android:radius="2dp" />
                </shape>
            </item>
            <item
                android:width="2dp"
                android:gravity="right"
                android:right="10dp"
                android:top="10dp"
                android:bottom="10dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/senku_surface_rule_warm" />
                    <corners android:radius="2dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:drawable="@drawable/bg_search_box" />
</selector>
