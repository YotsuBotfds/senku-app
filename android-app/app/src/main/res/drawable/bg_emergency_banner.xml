<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_surface_alert" />
        </shape>
    </item>

    <item
        android:gravity="top"
        android:height="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_rev03_danger" />
        </shape>
    </item>

    <item
        android:gravity="left"
        android:width="3dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_rev03_danger" />
        </shape>
    </item>

    <item
        android:gravity="bottom"
        android:height="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_rev03_hairline_strong" />
        </shape>
    </item>
</layer-list>
