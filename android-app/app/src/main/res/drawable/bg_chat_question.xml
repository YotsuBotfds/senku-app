<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_accent_olive_dark" />
            <corners
                android:topLeftRadius="22dp"
                android:topRightRadius="22dp"
                android:bottomLeftRadius="10dp"
                android:bottomRightRadius="22dp" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="@color/senku_bg_olive"
                android:startColor="@color/senku_accent_olive_dark" />
            <corners
                android:topLeftRadius="21dp"
                android:topRightRadius="21dp"
                android:bottomLeftRadius="9dp"
                android:bottomRightRadius="21dp" />
            <stroke
                android:width="1dp"
                android:color="@color/senku_accent_olive" />
        </shape>
    </item>

    <item
        android:left="12dp"
        android:top="10dp"
        android:right="12dp"
        android:bottom="42dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#00FFFFFF"
                android:startColor="#12FFFFFF" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</layer-list>
