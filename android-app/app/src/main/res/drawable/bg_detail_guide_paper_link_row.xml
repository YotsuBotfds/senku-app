<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#3CF7F0DF" />
            <stroke
                android:width="1dp"
                android:color="#78B9AA90" />
        </shape>
    </item>
    <item
        android:width="4dp"
        android:gravity="left">
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_rev03_paper_warn" />
        </shape>
    </item>
    <item
        android:height="1dp"
        android:gravity="bottom"
        android:left="8dp">
        <shape android:shape="rectangle">
            <solid android:color="#34B9AA90" />
        </shape>
    </item>
</layer-list>
