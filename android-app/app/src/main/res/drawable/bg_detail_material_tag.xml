<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_bg_shadow_warm" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="@color/senku_accent_olive_dark"
                android:startColor="@color/senku_bg_olive_moss" />
            <corners android:radius="11dp" />
            <stroke
                android:width="1dp"
                android:color="@color/senku_accent_olive" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#00000000"
                android:startColor="#14E8DCC8" />
            <corners android:radius="11dp" />
        </shape>
    </item>

    <item
        android:left="10dp"
        android:top="8dp"
        android:right="10dp"
        android:bottom="8dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="#00FFFFFF"
                android:startColor="#18FFFFFF" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</layer-list>
