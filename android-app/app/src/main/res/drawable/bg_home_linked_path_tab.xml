<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_bg_shadow_warm" />
            <corners android:radius="4dp" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="2dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_bg_primary" />
            <corners android:radius="3dp" />
            <stroke
                android:width="1dp"
                android:color="@color/senku_card_border" />
        </shape>
    </item>

    <item
        android:width="10dp"
        android:gravity="start"
        android:left="1dp"
        android:top="2dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="@color/senku_accent_olive"
                android:endColor="@color/senku_accent_olive" />
            <corners
                android:topLeftRadius="3dp"
                android:bottomLeftRadius="3dp"
                android:topRightRadius="2dp"
                android:bottomRightRadius="2dp" />
        </shape>
    </item>

    <item
        android:width="78dp"
        android:height="10dp"
        android:gravity="top|start"
        android:left="18dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#2EE8DCC8" />
            <corners
                android:topLeftRadius="2dp"
                android:topRightRadius="2dp"
                android:bottomLeftRadius="2dp"
                android:bottomRightRadius="2dp" />
        </shape>
    </item>
</layer-list>
