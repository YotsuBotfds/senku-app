<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_rev03_paper" />
            <corners android:radius="2dp" />
            <stroke
                android:width="1dp"
                android:color="#36B9AA90" />
        </shape>
    </item>
    <item
        android:height="1dp"
        android:gravity="top"
        android:left="10dp"
        android:right="10dp">
        <shape android:shape="rectangle">
            <solid android:color="#55B9AA90" />
        </shape>
    </item>
</layer-list>
