<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#E8F1E6D3" />
            <corners android:radius="1dp" />
            <stroke
                android:width="1dp"
                android:color="#34B9AA90" />
        </shape>
    </item>
    <item
        android:height="1dp"
        android:gravity="top"
        android:left="8dp"
        android:right="8dp">
        <shape android:shape="rectangle">
            <solid android:color="#3AB9AA90" />
        </shape>
    </item>
</layer-list>
