<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_rev03_paper" />
            <corners android:radius="@dimen/senku_rev03_corner_medium" />
            <stroke
                android:width="1dp"
                android:color="@color/senku_card_border" />
        </shape>
    </item>

    <item
        android:left="10dp"
        android:top="10dp"
        android:right="10dp"
        android:bottom="10dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_rev03_paper" />
            <corners android:radius="@dimen/senku_rev03_corner_small" />
        </shape>
    </item>
</layer-list>
