<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_rev03_paper" />
            <corners android:radius="1dp" />
            <stroke
                android:width="1dp"
                android:color="@color/senku_rev03_paper_rule_soft" />
        </shape>
    </item>
    <item
        android:top="1dp"
        android:left="1dp"
        android:right="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_rev03_paper_glaze" />
            <corners android:radius="0dp" />
        </shape>
    </item>
    <item
        android:height="1dp"
        android:gravity="top">
        <shape android:shape="rectangle">
            <solid android:color="@color/senku_rev03_paper_rule_soft" />
        </shape>
    </item>
</layer-list>
