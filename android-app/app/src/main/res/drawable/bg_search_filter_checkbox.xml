<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <layer-list>
            <item android:width="15dp" android:height="15dp" android:gravity="center">
                <shape android:shape="rectangle">
                    <corners android:radius="1dp" />
                    <solid android:color="@color/senku_rev03_accent" />
                    <stroke android:width="1dp" android:color="@color/senku_rev03_accent" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item android:width="15dp" android:height="15dp" android:gravity="center">
                <shape android:shape="rectangle">
                    <corners android:radius="1dp" />
                    <solid android:color="@android:color/transparent" />
                    <stroke android:width="1.5dp" android:color="@color/senku_rev03_accent" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
