<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/senku_rev03_bg_0"
    android:keepScreenOn="true"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/home_manual_stamp"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/home_subtitle"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="72dp"
        android:layout_height="match_parent"
        android:background="@color/senku_rev03_bg_0"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingTop="20dp">

        <TextView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_manual_home_nav_shell"
            android:fontFamily="@font/jetbrains_mono"
            android:gravity="center"
            android:includeFontPadding="false"
            android:letterSpacing="0.09"
            android:lineHeight="18sp"
            android:text="@string/app_badge_letter"
            android:textColor="@color/senku_rev03_accent"
            android:textFontWeight="700"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/phone_nav_home"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:contentDescription="@string/bottom_tab_home"
            android:gravity="center"
            android:minHeight="48dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/phone_nav_home_icon"
                android:layout_width="@dimen/senku_rev03_nav_rail_icon"
                android:layout_height="@dimen/senku_rev03_nav_rail_icon"
                android:contentDescription="@string/bottom_tab_home"
                android:src="@drawable/ic_home_library"
                android:tint="@color/senku_rev03_accent" />

            <TextView
                android:id="@+id/phone_nav_home_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/inter_tight"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="@string/bottom_tab_home"
                android:textAppearance="@style/TextAppearance.Senku.Rev03.NavLabel"
                android:textColor="@color/senku_rev03_accent"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/phone_nav_ask"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:contentDescription="@string/bottom_tab_ask"
            android:gravity="center"
            android:minHeight="48dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/phone_nav_ask_icon"
                android:layout_width="@dimen/senku_rev03_nav_rail_icon"
                android:layout_height="@dimen/senku_rev03_nav_rail_icon"
                android:contentDescription="@string/bottom_tab_ask"
                android:src="@drawable/ic_home_ask"
                android:tint="@color/senku_rev03_ink_2" />

            <TextView
                android:id="@+id/phone_nav_ask_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/inter_tight"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="@string/bottom_tab_ask"
                android:textAppearance="@style/TextAppearance.Senku.Rev03.NavLabel"
                android:textColor="@color/senku_rev03_ink_2" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/phone_nav_pins"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:contentDescription="@string/bottom_tab_pins"
            android:gravity="center"
            android:minHeight="48dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/phone_nav_pins_icon"
                android:layout_width="@dimen/senku_rev03_nav_rail_icon"
                android:layout_height="@dimen/senku_rev03_nav_rail_icon"
                android:contentDescription="@string/bottom_tab_pins"
                android:src="@drawable/ic_home_saved"
                android:tint="@color/senku_rev03_ink_2" />

            <TextView
                android:id="@+id/phone_nav_pins_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/inter_tight"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="@string/bottom_tab_pins"
                android:textAppearance="@style/TextAppearance.Senku.Rev03.NavLabel"
                android:textColor="@color/senku_rev03_ink_2" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="@color/senku_rev03_hairline_strong" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@color/senku_rev03_bg_0"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/home_chrome_row"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="3dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="3dp">

            <LinearLayout
                android:id="@+id/home_chrome_back_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:clickable="true"
                android:contentDescription="@string/detail_back_content_description"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="0dp"
                android:paddingEnd="0dp">

                <ImageView
                    android:id="@+id/home_chrome_back_icon"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_home_back_chevron"
                    android:tint="@color/senku_rev03_ink_0" />

                <TextView
                    android:id="@+id/home_chrome_back_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="0dp"
                    android:fontFamily="@font/jetbrains_mono"
                    android:importantForAccessibility="no"
                    android:includeFontPadding="false"
                    android:letterSpacing="0.09"
                    android:lineHeight="12sp"
                    android:maxLines="1"
                    android:text="@string/detail_back"
                    android:textColor="@color/senku_rev03_ink_0"
                    android:textFontWeight="500"
                    android:textSize="10sp"
                    android:visibility="gone" />
            </LinearLayout>

            <View
                android:id="@+id/home_chrome_divider"
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="10dp"
                android:background="@color/senku_rev03_hairline_strong" />

            <TextView
                android:id="@+id/home_chrome_mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/jetbrains_mono"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="HOME SENKU"
                android:textAppearance="@style/TextAppearance.Senku.Rev03.MonoCaps"
                android:textColor="@color/senku_rev03_accent"
                android:textFontWeight="500" />

            <TextView
                android:id="@+id/home_chrome_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:fontFamily="@font/inter_tight"
                android:includeFontPadding="false"
                android:lineHeight="18sp"
                android:maxLines="1"
                android:text="Field manual &#8226; ed.2"
                android:textColor="@color/senku_rev03_ink_0"
                android:textFontWeight="600"
                android:textSize="14sp" />

            <ImageView
                android:id="@+id/home_chrome_search_icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="@string/home_chrome_search_content_description"
                android:focusable="true"
                android:padding="15dp"
                android:src="@drawable/ic_search_magnifier"
                android:tint="@color/senku_rev03_ink_2" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:fontFamily="@font/jetbrains_mono"
                android:importantForAccessibility="no"
                android:includeFontPadding="false"
                android:text="..."
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textColor="@color/senku_rev03_ink_2"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <View
            android:id="@+id/home_chrome_bottom_rule"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/senku_rev03_hairline_strong" />

        <ScrollView
            android:id="@+id/browse_scroll_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:paddingStart="30dp"
            android:paddingEnd="30dp"
            android:paddingBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="4dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="Field manual"
                    android:textAppearance="?android:attr/textAppearanceLarge"
                    android:textColor="@color/senku_rev03_ink_0"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:includeFontPadding="false"
                    android:text="754 guides &#8226; 12 categories &#8226; ready offline &#8226; ed. 2"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textColor="@color/senku_rev03_ink_1" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_tablet_home_status_bar"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <TextView
                        android:id="@+id/status_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:accessibilityLiveRegion="polite"
                        android:fontFamily="@font/jetbrains_mono"
                        android:includeFontPadding="false"
                        android:text="@string/status_starting"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="@color/senku_rev03_ok"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/jetbrains_mono"
                        android:includeFontPadding="false"
                        android:text="754 GUIDES &#8226; ED.2 &#8226; 184 MB"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="@color/senku_rev03_ink_2"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="14dp"
                    android:addStatesFromChildren="true"
                    android:background="@color/senku_rev03_bg_0"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="8dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@string/search_input_description"
                        android:labelFor="@id/search_input"
                        android:padding="3dp"
                        android:src="@drawable/ic_search_magnifier"
                        android:tint="@color/senku_rev03_ink_2" />

                    <EditText
                        android:id="@+id/search_input"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:contentDescription="@string/search_input_description"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:hint="@string/search_hint"
                        android:importantForAutofill="no"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:maxLines="1"
                        android:fontFamily="@font/inter_tight"
                        android:includeFontPadding="false"
                        android:padding="0dp"
                        android:lineHeight="18sp"
                        android:textFontWeight="500"
                        android:textColor="@color/senku_rev03_ink_0"
                        android:textColorHint="@color/senku_rev03_ink_2"
                        android:textSize="14sp" />
                </LinearLayout>

                <HorizontalScrollView
                    android:id="@+id/search_suggestions_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fadingEdge="horizontal"
                    android:fadingEdgeLength="24dp"
                    android:scrollbars="none"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/search_suggestions_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </HorizontalScrollView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:layout_weight="1.02"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/category_section_header"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/jetbrains_mono"
                            android:includeFontPadding="false"
                            android:text="&#8212; CATEGORIES &#8226; 12"
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:textColor="@color/senku_rev03_ink_2"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:id="@+id/category_section_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:orientation="vertical" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/recent_threads_section"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.9"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/jetbrains_mono"
                            android:includeFontPadding="false"
                            android:text="@string/recent_threads_title"
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:textColor="@color/senku_rev03_ink_2"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:id="@+id/recent_threads_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:orientation="vertical" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/pinned_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/home_block_gap"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/pinned_section_title"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="@color/senku_rev03_ink_2"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/pinned_empty_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/home_compact_gap"
                        android:text="@string/saved_guides_empty"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="@color/senku_rev03_ink_2"
                        android:visibility="gone" />

                    <HorizontalScrollView
                        android:id="@+id/pinned_scroll"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/home_compact_gap"
                        android:fadingEdge="horizontal"
                        android:fadingEdgeLength="24dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/pinned_container"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal" />
                    </HorizontalScrollView>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:id="@+id/tablet_search_surface"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/results_header"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:accessibilityLiveRegion="polite"
                    android:ellipsize="end"
                    android:fontFamily="@font/jetbrains_mono"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="@string/results_header_loading"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textColor="@color/senku_rev03_ink_0"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/jetbrains_mono"
                    android:includeFontPadding="false"
                    android:text=""
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textColor="@color/senku_rev03_ink_2"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tablet_search_topbar_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="12dp"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingBottom="12dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@string/search_input_description"
                    android:src="@drawable/ic_search_magnifier"
                    android:tint="@color/senku_rev03_ink_2" />

                <TextView
                    android:id="@+id/tablet_search_query_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/inter_tight"
                    android:includeFontPadding="false"
                    android:lineHeight="18sp"
                    android:maxLines="1"
                    android:text="@string/search_hint"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textColor="@color/senku_rev03_ink_0"
                    android:textFontWeight="600"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tablet_search_count_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/jetbrains_mono"
                    android:includeFontPadding="false"
                    android:lineHeight="16sp"
                    android:text="0 RESULTS"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textColor="@color/senku_rev03_ink_2"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:id="@+id/tablet_search_bottom_rule"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/senku_rev03_hairline_strong"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="176dp"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:paddingStart="12dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/jetbrains_mono"
                        android:includeFontPadding="false"
                        android:text="FILTER &#8226; CATEGORY"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="@color/senku_rev03_ink_3"
                        android:textSize="11sp"
                        android:lineHeight="14sp"
                        android:textStyle="bold" />

                    <CheckBox
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:button="@drawable/bg_search_filter_checkbox"
                        android:drawablePadding="10dp"
                        android:clickable="false"
                        android:focusable="false"
                        android:fontFamily="@font/inter_tight"
                        android:includeFontPadding="false"
                        android:lineHeight="15sp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:text="Shelter (12)"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="@color/senku_rev03_ink_1"
                        android:textFontWeight="500"
                        android:textSize="12sp" />

                    <CheckBox
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:button="@drawable/bg_search_filter_checkbox"
                        android:drawablePadding="10dp"
                        android:clickable="false"
                        android:focusable="false"
                        android:fontFamily="@font/inter_tight"
                        android:includeFontPadding="false"
                        android:lineHeight="15sp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:text="Water (4)"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="@color/senku_rev03_ink_1"
                        android:textFontWeight="500"
                        android:textSize="12sp" />

                    <CheckBox
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:button="@drawable/bg_search_filter_checkbox"
                        android:drawablePadding="10dp"
                        android:clickable="false"
                        android:focusable="false"
                        android:fontFamily="@font/inter_tight"
                        android:includeFontPadding="false"
                        android:lineHeight="15sp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:text="Fire (3)"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="@color/senku_rev03_ink_1"
                        android:textFontWeight="500"
                        android:textSize="12sp" />

                    <CheckBox
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:button="@drawable/bg_search_filter_checkbox"
                        android:drawablePadding="10dp"
                        android:clickable="false"
                        android:focusable="false"
                        android:fontFamily="@font/inter_tight"
                        android:includeFontPadding="false"
                        android:lineHeight="15sp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:text="Survival (8)"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="@color/senku_rev03_ink_1"
                        android:textFontWeight="500"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:fontFamily="@font/jetbrains_mono"
                        android:includeFontPadding="false"
                        android:text="WINDOW"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="@color/senku_rev03_ink_3"
                        android:textSize="11sp"
                        android:lineHeight="14sp"
                        android:textStyle="bold" />

                    <CheckBox
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:button="@drawable/bg_search_filter_checkbox"
                        android:drawablePadding="10dp"
                        android:clickable="false"
                        android:focusable="false"
                        android:fontFamily="@font/inter_tight"
                        android:includeFontPadding="false"
                        android:lineHeight="15sp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:text="Immediate"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="@color/senku_rev03_ink_1"
                        android:textFontWeight="500"
                        android:textSize="12sp" />

                    <CheckBox
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:button="@drawable/bg_search_filter_checkbox"
                        android:drawablePadding="10dp"
                        android:clickable="false"
                        android:focusable="false"
                        android:fontFamily="@font/inter_tight"
                        android:includeFontPadding="false"
                        android:lineHeight="15sp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:text="Short"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="@color/senku_rev03_ink_1"
                        android:textFontWeight="500"
                        android:textSize="12sp" />

                    <CheckBox
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:button="@drawable/bg_search_filter_checkbox"
                        android:drawablePadding="10dp"
                        android:clickable="false"
                        android:focusable="false"
                        android:fontFamily="@font/inter_tight"
                        android:includeFontPadding="false"
                        android:lineHeight="15sp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:text="Long"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="@color/senku_rev03_ink_1"
                        android:textFontWeight="500"
                        android:textSize="12sp" />

                    <CheckBox
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:button="@drawable/bg_search_filter_checkbox"
                        android:drawablePadding="10dp"
                        android:clickable="false"
                        android:focusable="false"
                        android:fontFamily="@font/inter_tight"
                        android:includeFontPadding="false"
                        android:lineHeight="15sp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:text="Mixed"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="@color/senku_rev03_ink_1"
                        android:textFontWeight="500"
                        android:textSize="12sp" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/senku_rev03_hairline_strong" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/results_list"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:contentDescription="@string/results_list_description"
                    android:paddingTop="6dp"
                    android:paddingBottom="18dp" />

                <LinearLayout
                    android:id="@+id/tablet_search_preview_rail"
                    android:layout_width="236dp"
                    android:layout_height="match_parent"
                    android:background="@color/senku_rev03_bg_1"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="16dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tablet_search_preview_kicker"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/jetbrains_mono"
                        android:includeFontPadding="false"
                        android:text="PREVIEW"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="@color/senku_rev03_ink_2"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tablet_search_preview_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textAppearance="?android:attr/textAppearanceLarge"
                        android:textColor="@color/senku_rev03_ink_0"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tablet_search_preview_meta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="9dp"
                        android:fontFamily="@font/jetbrains_mono"
                        android:letterSpacing="0.08"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="@color/senku_rev03_ink_2"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tablet_search_preview_body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:lineSpacingExtra="2dp"
                        android:maxLines="4"
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:textColor="@color/senku_rev03_ink_1"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tablet_home_utility_views"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/info_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/info_loading" />

            <ProgressBar
                android:id="@+id/progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:indeterminate="true" />

            <Button
                android:id="@+id/search_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_search_button" />

            <Button
                android:id="@+id/browse_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/browse_guides_button" />

            <Button
                android:id="@+id/ask_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ask_button" />

            <Button
                android:id="@+id/import_model_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/import_model_button" />

            <Button
                android:id="@+id/host_inference_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/host_inference_off_button" />

            <Button
                android:id="@+id/reviewed_card_runtime_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reviewed_card_runtime_off_button" />

            <Button
                android:id="@+id/reinstall_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reinstall_pack_button" />

            <LinearLayout
                android:id="@+id/session_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/session_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <Button
                    android:id="@+id/clear_chat_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/clear_chat_button" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/home_related_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/home_related_subtitle_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <Button
                    android:id="@+id/home_related_anchor_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:id="@+id/home_related_empty_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <HorizontalScrollView
                    android:id="@+id/home_related_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:id="@+id/home_related_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </HorizontalScrollView>
            </LinearLayout>

            <TextView
                android:id="@+id/home_entry_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/home_entry_lanes" />

            <LinearLayout
                android:id="@+id/developer_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <Button
                    android:id="@+id/developer_toggle_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/developer_tools_show" />

                <LinearLayout
                    android:id="@+id/developer_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/developer_diagnostics_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
