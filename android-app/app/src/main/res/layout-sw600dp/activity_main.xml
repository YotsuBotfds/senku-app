<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_screen"
    android:keepScreenOn="true"
    android:orientation="horizontal"
    android:padding="@dimen/home_screen_padding">

    <LinearLayout
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_hero_panel"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/home_panel_padding">

            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_badge"
                android:gravity="center"
                android:text="@string/app_badge_letter"
                android:textAppearance="?android:attr/textAppearanceLarge"
                android:textColor="@color/senku_rev03_ink_0"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_inline_gap"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name_short"
                    android:textAppearance="?android:attr/textAppearanceLarge"
                    android:textColor="@color/senku_rev03_ink_0"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/home_header_meta_gap"
                    android:baselineAligned="false"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/home_manual_stamp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/home_serial_gap"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/jetbrains_mono"
                        android:letterSpacing="0.04"
                        android:maxLines="1"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="@color/senku_rev03_ink_2"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/home_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/home_subtitle"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="@color/senku_rev03_ink_2" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/home_inline_gap"
            android:accessibilityLiveRegion="polite"
            android:background="@drawable/bg_status_pill"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp"
            android:text="@string/status_starting"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="@color/senku_rev03_ink_0"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/info_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/home_block_gap"
            android:background="@drawable/bg_surface_panel"
            android:lineSpacingExtra="2dp"
            android:padding="@dimen/home_surface_padding"
            android:text="@string/info_loading"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="@color/senku_rev03_ink_2" />

        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/home_block_gap"
            android:indeterminate="true"
            android:indeterminateTint="@color/senku_rev03_accent"
            android:importantForAccessibility="no"
            android:progressTint="@color/senku_rev03_accent" />

        <LinearLayout
            android:id="@+id/session_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/home_major_gap"
            android:background="@drawable/bg_surface_panel"
            android:orientation="vertical"
            android:padding="@dimen/home_surface_padding"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/session_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/chat_memory_title"
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:textColor="@color/senku_rev03_ink_0"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/clear_chat_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_button_secondary"
                    android:text="@string/clear_chat_button"
                    android:textAllCaps="false"
                    android:textColor="@color/senku_rev03_ink_0" />
            </LinearLayout>

            <TextView
                android:id="@+id/session_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/home_compact_gap"
                android:lineSpacingExtra="2dp"
                android:maxLines="8"
                android:text="@string/chat_memory_empty"
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textColor="@color/senku_rev03_ink_2" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/developer_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/home_inline_gap"
            android:background="@drawable/bg_developer_panel"
            android:orientation="vertical"
            android:padding="@dimen/home_inline_gap">

            <Button
                android:id="@+id/developer_toggle_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_button_secondary"
                android:text="@string/developer_tools_show"
                android:textAllCaps="false"
                android:textColor="@color/senku_rev03_ink_0" />

            <LinearLayout
                android:id="@+id/developer_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/home_block_gap"
                android:orientation="vertical"
                android:visibility="gone">

                <Button
                    android:id="@+id/reviewed_card_runtime_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/home_compact_gap"
                    android:background="@drawable/bg_button_secondary"
                    android:text="@string/reviewed_card_runtime_off_button"
                    android:textAllCaps="false"
                    android:textColor="@color/senku_rev03_ink_0" />

                <TextView
                    android:id="@+id/reviewed_card_runtime_support_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/home_compact_gap"
                    android:text="@string/reviewed_card_runtime_support_text"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textColor="@color/senku_rev03_ink_2" />

                <TextView
                    android:id="@+id/developer_diagnostics_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/home_compact_gap"
                    android:background="@drawable/bg_surface_panel"
                    android:lineSpacingExtra="2dp"
                    android:padding="@dimen/home_surface_padding"
                    android:text="@string/info_loading"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textColor="@color/senku_rev03_ink_2" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/import_model_button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_secondary"
                        android:text="@string/import_model_button"
                        android:textAllCaps="false"
                        android:textColor="@color/senku_rev03_ink_0" />

                    <Button
                        android:id="@+id/reinstall_button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/home_compact_gap"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_secondary"
                        android:text="@string/reinstall_pack_button"
                        android:textAllCaps="false"
                        android:textColor="@color/senku_rev03_ink_0" />
                </LinearLayout>

                <Button
                    android:id="@+id/host_inference_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/home_compact_gap"
                    android:background="@drawable/bg_button_secondary"
                    android:text="@string/host_inference_off_button"
                    android:textAllCaps="false"
                    android:textColor="@color/senku_rev03_ink_0" />

            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:addStatesFromChildren="true"
            android:background="@drawable/bg_manual_home_search"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/home_search_shell_padding">

            <EditText
                android:id="@+id/search_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:contentDescription="@string/search_input_description"
                android:drawableStart="@drawable/ic_search_magnifier"
                android:drawablePadding="8dp"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:hint="@string/search_hint"
                android:importantForAutofill="no"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:paddingStart="@dimen/home_search_input_padding_horizontal"
                android:paddingTop="@dimen/home_search_input_padding_vertical"
                android:paddingEnd="@dimen/home_search_input_padding_horizontal"
                android:paddingBottom="@dimen/home_search_input_padding_vertical"
                android:textColor="@color/senku_rev03_ink_0"
                android:textColorHint="@color/senku_rev03_ink_2" />

        <Button
            android:id="@+id/search_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
                android:background="@drawable/bg_manual_home_row"
                android:minWidth="0dp"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
            android:text="@string/external_review_home_search_button"
            android:textAllCaps="false"
            android:textColor="@color/senku_rev03_ink_0" />
    </LinearLayout>

        <LinearLayout
            android:id="@+id/tablet_search_topbar_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="12dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="12dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@string/search_input_description"
                android:src="@drawable/ic_search_magnifier"
                android:tint="@color/senku_rev03_accent" />

            <TextView
                android:id="@+id/tablet_search_query_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:fontFamily="@font/inter_tight"
                android:includeFontPadding="false"
                android:lineHeight="18sp"
                android:maxLines="1"
                android:text="@string/search_hint"
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textColor="@color/senku_rev03_ink_0"
                android:textFontWeight="600"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tablet_search_count_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/jetbrains_mono"
                android:includeFontPadding="false"
                android:lineHeight="16sp"
                android:text="0 RESULTS"
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textColor="@color/senku_rev03_accent"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:id="@+id/tablet_search_bottom_rule"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="@color/senku_rev03_hairline_strong"
            android:visibility="gone" />

    <HorizontalScrollView
        android:id="@+id/search_suggestions_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/home_compact_gap"
        android:fadingEdge="horizontal"
        android:fadingEdgeLength="24dp"
        android:scrollbars="none"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/search_suggestions_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
            android:background="@drawable/bg_manual_home_nav_shell"
            android:layout_marginTop="@dimen/home_block_gap"
            android:orientation="horizontal"
            android:padding="@dimen/home_nav_shell_padding">

            <Button
                android:id="@+id/browse_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_manual_home_row"
                android:drawableStart="@drawable/ic_home_library"
                android:drawablePadding="8dp"
                android:text="@string/browse_guides_button"
                android:textAllCaps="false"
                android:textAppearance="@style/TextAppearance.Senku.Rev03.NavLabel"
                android:textColor="@color/senku_rev03_ink_0" />

        <Button
            android:id="@+id/ask_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/home_nav_segment_gap"
            android:layout_weight="1"
            android:background="@drawable/bg_manual_home_row"
            android:drawableStart="@drawable/ic_home_ask"
            android:drawablePadding="8dp"
            android:text="@string/ask_button"
            android:textAllCaps="false"
            android:textAppearance="@style/TextAppearance.Senku.Rev03.NavLabel"
            android:textColor="@color/senku_rev03_ink_0" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_nav_segment_gap"
                android:layout_weight="1"
                android:background="@drawable/bg_manual_home_row"
                android:drawableStart="@drawable/ic_home_saved"
                android:drawablePadding="8dp"
                android:gravity="center"
                android:minHeight="48dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/bottom_tab_pins"
                android:textAppearance="@style/TextAppearance.Senku.Rev03.NavLabel"
                android:textColor="@color/senku_rev03_ink_0" />
        </LinearLayout>

        <TextView
            android:id="@+id/home_entry_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/home_block_gap"
            android:lineSpacingExtra="2dp"
            android:text="@string/home_entry_lanes"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="@color/senku_rev03_ink_2" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="@dimen/home_block_gap"
            android:background="@drawable/bg_home_baseline_rule" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/home_section_gap"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/recent_threads_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/home_block_gap"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/recent_threads_title"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textColor="@color/senku_rev03_ink_2"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/recent_threads_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/home_compact_gap"
                    android:orientation="vertical" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/pinned_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/home_block_gap"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/pinned_section_title"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textColor="@color/senku_rev03_ink_2"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/pinned_empty_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/home_compact_gap"
                    android:text="@string/saved_guides_empty"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textColor="@color/senku_rev03_ink_2"
                    android:visibility="gone" />

                <HorizontalScrollView
                    android:id="@+id/pinned_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/home_compact_gap"
                    android:fadingEdge="horizontal"
                    android:fadingEdgeLength="24dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/pinned_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </HorizontalScrollView>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/home_related_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/home_block_gap"
                android:background="@drawable/bg_surface_panel"
                android:orientation="vertical"
                android:padding="@dimen/home_surface_padding"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/external_review_home_related_section_title"
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:textColor="@color/senku_rev03_ink_0"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/home_related_subtitle_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:lineSpacingExtra="2dp"
                    android:maxLines="2"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textColor="@color/senku_rev03_ink_2"
                    android:visibility="gone" />

        <Button
            android:id="@+id/home_related_anchor_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/home_compact_gap"
            android:background="@drawable/bg_home_linked_path_tab"
            android:gravity="start|center_vertical"
            android:minHeight="48dp"
            android:textAlignment="viewStart"
            android:textAllCaps="false"
            android:textColor="@color/senku_rev03_ink_0"
            android:visibility="gone" />

                <TextView
                    android:id="@+id/home_related_empty_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/home_compact_gap"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/external_review_home_related_empty"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textColor="@color/senku_rev03_ink_2"
                    android:visibility="gone" />

                <HorizontalScrollView
                    android:id="@+id/home_related_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/home_compact_gap"
                    android:fadingEdge="horizontal"
                    android:fadingEdgeLength="24dp"
                    android:scrollbars="none"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/home_related_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </HorizontalScrollView>
            </LinearLayout>

            <TextView
                android:id="@+id/category_section_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/category_section_title"
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:textColor="@color/senku_rev03_ink_0"
                android:textStyle="bold" />

            <ScrollView
                android:id="@+id/category_section_container"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/home_block_gap"
                android:layout_weight="1"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/category_water_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_category_tile"
                    android:backgroundTint="@color/senku_badge_water"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical"
                    android:padding="@dimen/home_surface_padding">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_category_water"
                        android:drawablePadding="8dp"
                        android:text="@string/category_water"
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:textColor="@color/senku_rev03_ink_0"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/category_water_count"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/category_count_placeholder"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="@color/senku_rev03_ink_0" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/category_shelter_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/home_category_gap"
                    android:layout_weight="1"
                    android:background="@drawable/bg_category_tile"
                    android:backgroundTint="@color/senku_badge_shelter"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical"
                    android:padding="@dimen/home_surface_padding">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_category_shelter"
                        android:drawablePadding="8dp"
                        android:text="@string/category_shelter"
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:textColor="@color/senku_rev03_ink_0"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/category_shelter_count"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/category_count_placeholder"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="@color/senku_rev03_ink_0" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/category_fire_card"
                    android:layout_width="0dp"
