<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_manual_phone_home_root"
    android:keepScreenOn="true"
    android:orientation="horizontal"
    android:paddingStart="0dp"
    android:paddingTop="0dp"
    android:paddingEnd="4dp"
    android:paddingBottom="2dp">

    <LinearLayout
        android:layout_width="64dp"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingTop="12dp">

        <TextView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_manual_home_nav_shell"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="@string/app_badge_letter"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="@color/senku_rev03_accent"
            android:textStyle="bold" />

        <FrameLayout
            android:id="@+id/phone_nav_home"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="18dp"
            android:contentDescription="@string/bottom_tab_home"
            android:minHeight="48dp">

            <View
                android:layout_width="2dp"
                android:layout_height="28dp"
                android:layout_gravity="start|center_vertical"
                android:background="@color/senku_rev03_accent" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/phone_nav_home_icon"
                    android:layout_width="@dimen/senku_rev03_nav_rail_icon"
                    android:layout_height="@dimen/senku_rev03_nav_rail_icon"
                    android:contentDescription="@string/bottom_tab_home"
                    android:padding="1dp"
                    android:src="@drawable/ic_home_library"
                    android:tint="@color/senku_rev03_accent" />

                <TextView
                    android:id="@+id/phone_nav_home_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="@string/bottom_tab_home"
                    android:textAppearance="@style/TextAppearance.Senku.Rev03.NavLabel"
                    android:textColor="@color/senku_rev03_accent"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/phone_nav_ask"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="4dp"
            android:contentDescription="@string/bottom_tab_ask"
            android:gravity="center"
            android:minHeight="48dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/phone_nav_ask_icon"
                android:layout_width="@dimen/senku_rev03_nav_rail_icon"
                android:layout_height="@dimen/senku_rev03_nav_rail_icon"
                android:contentDescription="@string/bottom_tab_ask"
                android:padding="1dp"
                android:src="@drawable/ic_home_ask"
                android:tint="@color/senku_rev03_ink_2" />

            <TextView
                android:id="@+id/phone_nav_ask_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="@string/bottom_tab_ask"
                android:textAppearance="@style/TextAppearance.Senku.Rev03.NavLabel"
                android:textColor="@color/senku_rev03_ink_2" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/phone_nav_pins"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="4dp"
            android:contentDescription="@string/bottom_tab_pins"
            android:gravity="center"
            android:minHeight="48dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/phone_nav_pins_icon"
                android:layout_width="@dimen/senku_rev03_nav_rail_icon"
                android:layout_height="@dimen/senku_rev03_nav_rail_icon"
                android:contentDescription="@string/bottom_tab_pins"
                android:padding="1dp"
                android:src="@drawable/ic_home_saved"
                android:tint="@color/senku_rev03_ink_2" />

            <TextView
                android:id="@+id/phone_nav_pins_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="@string/bottom_tab_pins"
                android:textAppearance="@style/TextAppearance.Senku.Rev03.NavLabel"
                android:textColor="@color/senku_rev03_ink_2" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:layout_marginEnd="0dp"
        android:background="@color/senku_rev03_hairline_strong" />

    <ScrollView
        android:id="@+id/browse_scroll_view"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingEnd="2dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="8dp">

            <LinearLayout
                android:id="@+id/home_chrome_row"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingTop="0dp"
                android:paddingEnd="12dp"
                android:paddingBottom="0dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/home_manual_stamp"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/home_subtitle"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/home_chrome_back_button"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:clickable="true"
                    android:contentDescription="@string/detail_back_content_description"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp">

                    <ImageView
                        android:id="@+id/home_chrome_back_icon"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_home_back_chevron"
                        android:tint="@color/senku_rev03_ink_0" />

                    <TextView
                        android:id="@+id/home_chrome_back_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="0dp"
                        android:fontFamily="@font/jetbrains_mono"
                        android:importantForAccessibility="no"
                        android:includeFontPadding="false"
                        android:letterSpacing="0.09"
                        android:lineHeight="12sp"
                        android:maxLines="1"
                        android:text="@string/detail_back"
                        android:textColor="@color/senku_rev03_ink_0"
                        android:textFontWeight="500"
                        android:textSize="10sp"
                        android:visibility="gone" />
                </LinearLayout>

                <View
                    android:id="@+id/home_chrome_divider"
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="10dp"
                    android:background="@color/senku_rev03_hairline_strong" />

                <TextView
                    android:id="@+id/home_chrome_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/jetbrains_mono"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="HOME SENKU"
                    android:textAppearance="@style/TextAppearance.Senku.Rev03.MonoCaps"
                    android:textColor="@color/senku_rev03_accent"
                    android:textFontWeight="500" />

                <TextView
                    android:id="@+id/home_chrome_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/inter_tight"
                    android:includeFontPadding="false"
                    android:lineHeight="18sp"
                    android:maxLines="1"
                    android:text="Field manual &#8226; ed.2"
                    android:textColor="@color/senku_rev03_ink_0"
                    android:textFontWeight="600"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/home_chrome_search_icon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:contentDescription="@string/home_chrome_search_content_description"
                    android:focusable="true"
                    android:padding="15dp"
                    android:src="@drawable/ic_search_magnifier"
                    android:tint="@color/senku_rev03_ink_2" />
            </LinearLayout>

            <View
                android:id="@+id/home_chrome_bottom_rule"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/senku_rev03_hairline_strong" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="24dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_manual_home_status"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="10dp"
                android:paddingEnd="10dp">

                <TextView
                    android:id="@+id/status_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:accessibilityLiveRegion="polite"
                    android:ellipsize="end"
                    android:fontFamily="monospace"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="@string/status_starting"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textColor="@color/senku_rev03_ok"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/info_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="monospace"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="@string/info_loading"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textColor="@color/senku_rev03_ink_2"
                    android:textStyle="bold" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="3dp"
                android:indeterminate="true"
                android:indeterminateTint="@color/senku_rev03_accent"
                android:importantForAccessibility="no"
                android:progressTint="@color/senku_rev03_accent"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="18dp"
                android:addStatesFromChildren="true"
                android:background="@drawable/bg_manual_home_search"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_manual_home_search_icon"
                    android:importantForAccessibility="no"
                    android:labelFor="@id/search_input"
                    android:padding="9dp"
                    android:src="@drawable/ic_search_magnifier"
                    android:tint="@color/senku_rev03_accent" />

                <EditText
                    android:id="@+id/search_input"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/search_input_description"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:hint="@string/search_hint"
                    android:importantForAutofill="no"
                    android:imeOptions="actionSearch"
                    android:includeFontPadding="false"
                    android:inputType="text"
                    android:maxLines="1"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    android:textColor="@color/senku_rev03_ink_0"
                    android:textColorHint="@color/senku_rev03_ink_2"
                    android:textSize="15sp" />
            </LinearLayout>

            <HorizontalScrollView
                android:id="@+id/search_suggestions_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fadingEdge="horizontal"
                android:fadingEdgeLength="24dp"
                android:scrollbars="none"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/search_suggestions_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <TextView
                android:id="@+id/category_section_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="monospace"
                android:includeFontPadding="false"
                android:text="&#8212; CATEGORIES &#8226; 12"
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textColor="@color/senku_rev03_ink_2"
                android:textSize="9sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/category_section_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="6dp"
                android:background="@color/senku_rev03_hairline_strong" />

            <LinearLayout
                android:id="@+id/browse_rail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="monospace"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="@string/home_entry_lanes"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textColor="@color/senku_rev03_ink_2"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/pinned_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:includeFontPadding="false"
                        android:text="@string/pinned_section_title"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="@color/senku_rev03_ink_2"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/pinned_empty_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/saved_guides_empty"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="@color/senku_rev03_ink_2"
                        android:visibility="gone" />

                    <HorizontalScrollView
                        android:id="@+id/pinned_scroll"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fadingEdge="horizontal"
                        android:fadingEdgeLength="24dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/pinned_container"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal" />
                    </HorizontalScrollView>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/recent_threads_section"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.72"
        android:background="@android:color/transparent"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="38dp"
        android:paddingEnd="0dp"
        android:paddingBottom="8dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="monospace"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="@string/recent_threads_title"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="@color/senku_rev03_ink_2"
            android:textSize="9sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/recent_threads_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/phone_landscape_search_surface"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.62"
        android:background="@android:color/transparent"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingTop="2dp"
        android:paddingEnd="10dp"
        android:paddingBottom="0dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/results_header"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:accessibilityLiveRegion="polite"
            android:ellipsize="end"
            android:fontFamily="monospace"
            android:gravity="center_vertical"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="@string/results_header_loading"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="@color/senku_rev03_ink_2"
            android:textSize="9sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/phone_search_query_well"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:layout_marginBottom="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:importantForAccessibility="no"
                android:padding="2dp"
                android:src="@drawable/ic_search_magnifier"
                android:tint="@color/senku_rev03_accent" />

            <TextView
                android:id="@+id/phone_search_query_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:fontFamily="monospace"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="@string/search_hint"
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textColor="@color/senku_rev03_ink_0"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/phone_search_count_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:includeFontPadding="false"
                android:text="0 RESULTS"
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textColor="@color/senku_rev03_accent"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/results_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:contentDescription="@string/results_list_description"
            android:paddingTop="1dp"
            android:paddingBottom="0dp"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/home_utility_views"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:visibility="gone">

        <Button
            android:id="@+id/search_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/external_review_home_search_button" />

        <Button
            android:id="@+id/browse_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/browse_guides_button" />

        <Button
            android:id="@+id/ask_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ask_button" />

        <TextView
            android:id="@+id/home_entry_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/home_entry_lanes" />

        <Button
            android:id="@+id/import_model_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/import_model_button" />

        <Button
            android:id="@+id/host_inference_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/host_inference_off_button" />

        <Button
            android:id="@+id/reviewed_card_runtime_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reviewed_card_runtime_off_button" />

        <TextView
            android:id="@+id/reviewed_card_runtime_support_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reviewed_card_runtime_support_text" />

        <Button
            android:id="@+id/reinstall_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reinstall_pack_button" />

        <LinearLayout
            android:id="@+id/session_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/session_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/clear_chat_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/clear_chat_button" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/home_related_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/home_related_subtitle_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/home_related_anchor_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/home_related_empty_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <HorizontalScrollView
                android:id="@+id/home_related_scroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:id="@+id/home_related_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/developer_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button
                android:id="@+id/developer_toggle_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/developer_tools_show" />

            <LinearLayout
                android:id="@+id/developer_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/developer_diagnostics_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </LinearLayout>

        <ScrollView
            android:id="@+id/developer_scroll_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>
</LinearLayout>
